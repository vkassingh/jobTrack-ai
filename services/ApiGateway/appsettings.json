{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "resume-route": {
        "ClusterId": "resume-cluster",
        "Match": {
          "Path": "/api/resumes/{**catch-all}"
        }
      },
      "applications-route": {
        "ClusterId": "applications-cluster",
        "Match": {
          "Path": "/api/applications/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth-destination": {
            "Address": "http://localhost:5104"
          }
        }
      },
      "resume-cluster": {
        "Destinations": {
          "resume-destination": {
            "Address": "http://localhost:5250"
          }
        }
      },
      "applications-cluster": {
        "Destinations": {
          "applications-destination": {
            "Address": "http://localhost:5276"
          }
        }
      }
    }
  }
}
